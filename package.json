{
	"name": "routa-repo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"scripts": {
		"build": "turbo run build",
		"check": "turbo run check",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "turbo run lint",
		"lint:repo": "biome lint .",
		"quality": "turbo run lint check test",
		"test": "turbo run test"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/node": "^24.0.4",
		"turbo": "^2.8.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4",
		"yaml": "2.9.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
