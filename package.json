{
	"name": "routa-repo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.9.0",
	"scripts": {
		"build": "turbo run build",
		"check": "biome check .",
		"changeset": "changeset",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "turbo run lint",
		"lint:repo": "biome lint .",
		"pack:check": "node scripts/pack-check.mjs",
		"prepare:local-cli": "pnpm --filter './packages/*' build && node scripts/link-local-cli.mjs",
		"quality": "pnpm check && turbo run typecheck test",
		"release": "pnpm run prepare:local-cli && pnpm quality && pnpm build && pnpm pack:check && changeset publish",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"version": "changeset version"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^26.1.0",
		"esbuild": "^0.28.1",
		"turbo": "^2.8.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"yaml": "2.9.0"
	}
}
