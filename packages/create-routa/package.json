{
	"name": "create-routa",
	"version": "0.0.0",
	"private": false,
	"type": "module",
	"bin": {
		"create-routa": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ../../scripts/build-package.mjs create-routa",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome lint src",
		"test": "vitest run"
	}
}
