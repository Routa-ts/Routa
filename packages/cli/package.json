{
	"name": "@routa-ts/cli",
	"version": "0.1.2",
	"description": "CLI for Routa route checks, scaffolding, and dev server",
	"private": false,
	"type": "module",
	"license": "MIT",
	"keywords": [
		"routa",
		"cli",
		"rest",
		"typescript",
		"openapi",
		"scaffold"
	],
	"homepage": "https://routa-ts.dev",
	"bugs": {
		"url": "https://github.com/Routa-ts/Routa/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Routa-ts/Routa.git",
		"directory": "packages/cli"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"routa": "dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ../../scripts/build-package.mjs @routa-ts/cli",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome lint src",
		"test": "vitest run"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.6",
		"@routa-ts/core": "workspace:*",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"yaml": "2.9.0"
	},
	"devDependencies": {
		"create-routa-ts": "workspace:*"
	}
}
