{
	"name": "@routa/cli",
	"version": "0.0.0",
	"private": false,
	"type": "module",
	"bin": {
		"routa": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome lint src",
		"test": "vitest run"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.6",
		"@routa/core": "workspace:*",
		"create-routa": "workspace:*",
		"tsx": "^4.22.4",
		"typescript": "^5.8.3",
		"yaml": "2.9.0"
	}
}
