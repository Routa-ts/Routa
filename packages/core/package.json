{
	"name": "@routa/core",
	"version": "0.0.1",
	"private": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./query/helpers": {
			"types": "./dist/query/helpers.d.ts",
			"import": "./dist/query/helpers.js"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.js"
		},
		"./logger": {
			"types": "./dist/logger.d.ts",
			"import": "./dist/logger.js"
		},
		"./middleware/auth": {
			"types": "./dist/middleware/auth.d.ts",
			"import": "./dist/middleware/auth.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ../../scripts/build-package.mjs @routa/core",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome lint src",
		"test": "vitest run"
	},
	"dependencies": {
		"hono": "^4.12.27",
		"zod": "^4.4.3"
	}
}
