{
	"name": "@routa-ts/core",
	"version": "0.1.0",
	"description": "Schema-first REST framework core for Routa",
	"private": false,
	"type": "module",
	"license": "MIT",
	"keywords": [
		"routa",
		"rest",
		"typescript",
		"hono",
		"zod",
		"openapi"
	],
	"homepage": "https://github.com/joseAcevesG/Routa#readme",
	"bugs": {
		"url": "https://github.com/joseAcevesG/Routa/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/joseAcevesG/Routa.git",
		"directory": "packages/core"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./query/helpers": {
			"types": "./dist/query/helpers.d.ts",
			"import": "./dist/query/helpers.js"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.js"
		},
		"./logger": {
			"types": "./dist/logger.d.ts",
			"import": "./dist/logger.js"
		},
		"./middleware/auth": {
			"types": "./dist/middleware/auth.d.ts",
			"import": "./dist/middleware/auth.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node ../../scripts/build-package.mjs @routa-ts/core",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
		"lint": "biome lint src",
		"test": "vitest run"
	},
	"peerDependencies": {
		"hono": "^4.12.27",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"hono": "^4.12.27",
		"zod": "^4.4.3"
	}
}
