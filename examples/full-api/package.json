{
	"name": "full-api",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "routa dev",
		"start": "routa start",
		"check": "routa check",
		"generate": "routa generate",
		"build": "routa build",
		"lint": "biome check .",
		"format": "biome check --write .",
		"scaffold": "pnpm scaffold:preview",
		"scaffold:preview": "cd scaffold && routa scaffold openapi.yaml --preview",
		"scaffold:update": "cd scaffold && routa scaffold openapi.yaml --yes",
		"openapi:check": "routa openapi check",
		"openapi:breaking": "routa openapi breaking",
		"openapi:update": "routa openapi breaking --update-baseline",
		"routes": "routa routes",
		"routes:json": "routa routes --format json",
		"logger:exercise": "node scripts/exercise-logger.mjs",
		"mint-session": "node scripts/mint-session.mjs"
	},
	"dependencies": {
		"@routa-ts/cli": "workspace:*",
		"@routa-ts/core": "workspace:*",
		"hono": "^4.12.27",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.23.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/node": "26.1.1",
		"typescript": "7.0.2"
	}
}
